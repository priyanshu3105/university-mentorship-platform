# Server (match backend default; Vite proxies /api and /socket.io to this port in dev)
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Frontend origin for CORS + Socket.IO (include if not on localhost:8080/5173/3000)
# FRONTEND_URL=http://localhost:8080

# Set true only for local dev to allow DMs without a confirmed booking (direct chat guard)
# ALLOW_DM_WITHOUT_BOOKING=false

# SMTP (optional for booking emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-pass
# EMAIL_FROM="MentorConnect <no-reply@example.com>"
# BOOKING_ATTACH_ICS=true
